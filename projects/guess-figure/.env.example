# 本地 dev 用。CF Pages 生产环境的 env vars 在 dashboard 配置
# cp .env.example .env 并填入实际值

# === 001 (现有) ===
YUNWU_API_KEY=
YUNWU_BASE_URL=https://yunwu.ai/v1
LLM_MODEL=gemini-3.1-flash-lite

# === 002 新增 — 限流 / LLM 预算 (SPEC C3) ===
# Stage 3 Prototype 实测云雾单次 ¥0.000526; 默认 8000/天 = ¥4.2/天容忍
LLM_BUDGET_DAILY=8000
# 单 user 日 LLM 上限 (Q 计数器, SPEC G2)
LLM_BUDGET_PER_USER=50
# 单 IP 日总请求上限 (Q 计数器, SPEC G6)
RATE_LIMIT_PER_IP_DAILY=200
# 单 user 日总请求上限 (Q 计数器, SPEC G6)
RATE_LIMIT_PER_USER_DAILY=200
# cookie HMAC 签名密钥, 32 字符随机 hex (SPEC C4)
# 生成: openssl rand -hex 32
# 警告: 不可轻易轮换 (轮换 = 所有匿名 user 身份归零)
AUTH_HMAC_SECRET=

# === 004 新增 — 海龟汤 RAG Cloudflare 资源契约 ===
# Vectorize V2: guess-figure-turtle-rag, 1024 维, cosine
# 创建命令: pnpm exec wrangler vectorize create guess-figure-turtle-rag --dimensions=1024 --metric=cosine
# R2 bucket: guess-figure-turtle-corpus
# 创建命令: pnpm exec wrangler r2 bucket create guess-figure-turtle-corpus
# Workers AI binding 名称: AI
RAG_EMBEDDING_MODEL=@cf/qwen/qwen3-embedding-0.6b
RAG_INDEX_VERSION=turtle-rag-v1
RAG_CORPUS_BUCKET=guess-figure-turtle-corpus
RAG_VECTOR_DIMENSIONS=1024
RAG_VECTOR_METRIC=cosine

# 本地离线构建脚本调用 Workers AI REST 生成真实 embedding 时需要。
# 生产 Pages runtime 使用 [ai] binding，不读取这两个值。
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
