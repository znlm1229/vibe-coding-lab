# 项目级 .gitignore（仓库根 .gitignore 之外的项目特定规则）

# 环境变量（含 LLM API key）
.env
.env.local
.env.*.local

# SvelteKit / Vite
.svelte-kit/
build/
.vercel/
.wrangler/

# Node
node_modules/

# Python（scripts/ 用）
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# 脚本输出 / 中间产物
scripts/logs/
figures-new.json
figures-batch*.json

# 日志
*.log
