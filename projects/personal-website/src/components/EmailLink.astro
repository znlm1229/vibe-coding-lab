---
// 邮箱混淆链接组件
// 满足 SPEC AC10：HTML 源码不含明文邮箱字符串；客户端 JS 启用后渲染为可点击 mailto: 链接 + 显示真实邮箱
// 实现：构建期 base64 编码 → 运行期客户端 atob 解码
//
// 注意（v2 修复 Stage 8 发现的 bug）：
// 原版用普通 `<script>`，Astro 在 starter 启用 ClientRouter 视图过渡时未正确 bundle
// 导致脚本根本不上 HTML，邮箱永远显示 fallback 文字。
// 改用 `is:inline` 强制内联 + 监听 `astro:page-load` 兼容初始加载与软切换页面两种场景。

interface Props {
  /** 真实邮箱地址，仅在构建期可见，会被 base64 编码后写入 data-email */
  email: string;
  /** 自定义显示文字；不传则启用 JS 后自动替换为真实邮箱 */
  text?: string;
  /** 透传 class */
  class?: string;
}

const { email, text, class: className = "" } = Astro.props;

// 用 base64 编码后整个串失去 email 字面特征
const encoded = Buffer.from(email).toString("base64");
const fallbackText = text ?? "邮箱（启用 JS 后显示）";
const autoFill = text == null;
---

<a
  href="#"
  data-email={encoded}
  data-autofill={autoFill ? "1" : undefined}
  class:list={["email-link", className]}
  rel="nofollow"
>
  {fallbackText}
</a>

<script is:inline>
  (function () {
    function setupEmailLinks() {
      document.querySelectorAll("a.email-link").forEach(function (a) {
        var enc = a.dataset.email;
        if (!enc) return;
        // 幂等：已处理过的元素跳过
        if (a.href && a.href.indexOf("mailto:") === 0) return;
        try {
          var email = atob(enc);
          a.href = "mailto:" + email;
          if (a.dataset.autofill === "1") {
            a.textContent = email;
          }
        } catch (e) {
          // base64 解码异常容错：保持原状
        }
      });
    }
    // 1) 初始硬加载（DOMContentLoaded 后或脚本位置之后立即执行）
    setupEmailLinks();
    // 2) ClientRouter 软切换页面后重跑（关键修复 v2）
    document.addEventListener("astro:page-load", setupEmailLinks);
  })();
</script>
