---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import EmailLink from "@/components/EmailLink.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";

// 最近博客（取 2 篇）
const posts = await getCollection("posts", ({ data }) => !data.draft);
const recentPosts = getSortedPosts(posts).slice(0, 2);

// 精选项目（featured 优先，最多 2 张展示在首页）
const projects = (
  await getCollection("projects", ({ data }) => !data.draft)
)
  .sort((a, b) => {
    const fA = a.data.featured ? 1 : 0;
    const fB = b.data.featured ? 1 : 0;
    if (fA !== fB) return fB - fA;
    return (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .slice(0, 2);
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path="/"
    class="app-layout"
  >
    {/* Hero：头像 + 名字 + 一句自我定位 */}
    <section
      id="hero"
      class="border-border flex flex-col items-start gap-6 border-b pt-8 pb-8 sm:flex-row sm:items-center"
    >
      <img
        src="/avatar.svg"
        alt="李旺的头像"
        width="120"
        height="120"
        class="border-border bg-card rounded-full border"
      />
      <div>
        <h1 class="text-3xl font-bold sm:text-4xl">李旺</h1>
        <p class="text-muted-foreground mt-2 text-lg">
          中文技术圈开发者 · 后端 / Java 为主 · 业余用 AI 辅助开发做点东西
        </p>
      </div>
    </section>

    {/* 精选项目 */}
    {
      projects.length > 0 && (
        <section
          id="featured-projects"
          class="border-border border-b py-8"
        >
          <h2 class="text-2xl font-semibold">精选项目</h2>
          <ul class="mt-4 grid gap-4 sm:grid-cols-2">
            {projects.map(p => (
              <li class="border-border bg-card hover:border-accent rounded-lg border transition-colors">
                <a
                  href={`/projects/${p.id}/`}
                  class="block h-full p-4 no-underline"
                >
                  <h3 class="text-accent text-lg font-semibold">
                    {p.data.title}
                  </h3>
                  <p class="text-muted-foreground mt-2 text-sm">
                    {p.data.summary}
                  </p>
                </a>
              </li>
            ))}
          </ul>
          <p class="mt-4 text-sm">
            <a href="/projects/" class="text-accent underline">
              查看全部项目 →
            </a>
          </p>
        </section>
      )
    }

    {/* 最近博客 */}
    {
      recentPosts.length > 0 && (
        <section
          id="recent-posts"
          class="border-border border-b py-8"
        >
          <h2 class="text-2xl font-semibold">最近博客</h2>
          <ul class="mt-4 space-y-4">
            {recentPosts.map(p => (
              <li class="border-border bg-card hover:border-accent rounded-lg border p-4 transition-colors">
                <a href={`/posts/${p.id}/`} class="block no-underline">
                  <h3 class="text-accent text-lg font-semibold">
                    {p.data.title}
                  </h3>
                  <p class="text-muted-foreground mt-2 text-sm">
                    {p.data.description}
                  </p>
                  <time
                    class="text-muted-foreground mt-2 block text-xs"
                    datetime={p.data.pubDatetime.toISOString()}
                  >
                    {p.data.pubDatetime.toISOString().slice(0, 10)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
          <p class="mt-4 text-sm">
            <a href="/posts/" class="text-accent underline">
              查看全部博客 →
            </a>
          </p>
        </section>
      )
    }

    {/* 联系入口 */}
    <section id="contact" class="py-8">
      <h2 class="text-2xl font-semibold">联系</h2>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <strong>GitHub</strong>：
          <a
            href="https://github.com/znlm1229"
            class="text-accent underline"
            rel="noopener"
            target="_blank">@znlm1229</a>
        </li>
        <li>
          <strong>邮箱</strong>：<EmailLink email="617809914@qq.com" />
        </li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
