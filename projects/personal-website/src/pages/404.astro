---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import config from "@/config";
---

<Layout title={`找不到页面 | ${config.site.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center text-center">
      <h1 class="text-accent text-9xl font-bold">404</h1>
      <span aria-hidden="true" class="text-muted-foreground mt-2">
        ¯\_(ツ)_/¯
      </span>
      <p class="mt-4 text-2xl sm:text-3xl">这一页找不到了</p>
      <p class="text-muted-foreground mt-2 text-sm">
        URL 可能拼错了，或者内容已经搬走 / 删掉了
      </p>
      <LinkButton
        href="/"
        class="my-6 text-lg underline decoration-dashed underline-offset-8"
      >
        回首页
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>
